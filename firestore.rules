rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own user document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Family documents
    match /families/{familyId} {
      // Allow creation of a NEW family only if the authenticated user is setting
      // themselves as the owner (used during first-time family setup)
      allow create: if request.auth != null
                    && request.resource.data.ownerId == request.auth.uid;

      // Allow read/update/delete only to members of this family
      allow read, update, delete: if request.auth != null && isInFamily(familyId);

      // Members subcollection
      match /members/{memberId} {
        allow read, write: if request.auth != null && isInFamily(familyId);
      }

      // Tasks subcollection
      match /tasks/{taskId} {
        allow read, write: if request.auth != null && isInFamily(familyId);
      }
    }
  }

  // Helper: check if the authenticated user belongs to this family
  function isInFamily(familyId) {
    let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
    return userDoc.exists() && userDoc.data.familyId == familyId;
  }
}
