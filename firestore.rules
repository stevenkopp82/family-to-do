rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own user document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Family and ALL subcollections — single rule block using ** wildcard
    match /families/{familyId}/{document=**} {
      allow read, write: if request.auth != null && isInFamily(familyId);
    }

    // Family document creation — new user setting up their family
    match /families/{familyId} {
      allow create: if request.auth != null
                    && request.resource.data.ownerId == request.auth.uid;
    }
  }

  function isInFamily(familyId) {
    let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
    return userDoc.exists() && userDoc.data.familyId == familyId;
  }
}
